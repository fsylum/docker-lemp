[mysqld]
# InnoDB buffer pool — the single most important MySQL tuning parameter.
# ~50% of the container memory limit (512MB). Only allocate more if MySQL
# is the primary bottleneck and you increase the container limit.
innodb_buffer_pool_size = 256M

# Redo log capacity — larger logs reduce checkpoint frequency, improving
# write performance at the cost of longer crash recovery.
innodb_redo_log_capacity = 256M

# Slow query log — essential for identifying performance problems.
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow.log
long_query_time = 1

# Max connections — PHP-FPM max_children=8 means at most 8 concurrent
# connections per site. 50 leaves headroom for admin and monitoring.
max_connections = 50

# Disable performance schema to save ~100MB RAM.
# Re-enable if you need detailed query analysis.
performance_schema = OFF

# Log errors to stderr so Docker captures them.
log_error = /dev/stderr

# Skip reverse DNS lookups — faster connection setup.
skip_name_resolve = 1
